      <div class="reckitt-divider"></div>
      <div class="reckitt-sub">Hull Site<br>Gaviscon Bottles</div>
    </div>
  </div>
</div>


<div class="filter-group">
  <div class="filters">
    <span class="filter-label">By horizon:</span>
    <button class="filter-btn active all" onclick="filterHorizon('all', this)">All</button>
    <button class="filter-btn now" onclick="filterHorizon('now', this)">Now</button>
    <button class="filter-btn short" onclick="filterHorizon('short', this)">Short</button>
    <button class="filter-btn medium" onclick="filterHorizon('medium', this)">Medium</button>
    <button class="filter-btn strategic" onclick="filterHorizon('strategic', this)">Strategic</button>
    <div class="search-wrap">
      <span class="search-icon">⌕</span>
      <input class="search-input" type="text" placeholder="Search opportunities..." oninput="search(this.value)" id="searchInput">
    </div>
  </div>
</div>

<div class="filter-group">
  <div class="filters">
    <span class="filter-label">By process area:</span>
    <button class="filter-btn active all" onclick="filterArea('all', this)">All areas</button>
    <button class="filter-btn area-inbound"   onclick="filterArea('inbound-quality', this)">Inbound Quality</button>
    <button class="filter-btn area-dispensary" onclick="filterArea('dispensary', this)">Dispensary</button>
    <button class="filter-btn area-processing" onclick="filterArea('processing', this)">Processing</button>
    <button class="filter-btn area-fillpack"   onclick="filterArea('fill-pack', this)">Packing</button>
    <button class="filter-btn area-qcrelease"  onclick="filterArea('qc-release', this)">QC &amp; Release</button>
    <button class="filter-btn area-dispatch"   onclick="filterArea('dispatch', this)">Dispatch</button>
  </div>
</div>

<div class="count-line" id="countLine">Showing <span id="countNum">19</span> of 19 opportunities</div>

<div class="table-wrap">

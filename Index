<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gaviscon VSM — Opportunity &amp; Next Steps</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #ffffff;
    --surface: #f8f9fb;
    --surface2: #f0f2f6;
    --border: #e2e6ef;
    --text: #1a1e2e;
    --muted: #6b7280;
    --now: #22c55e;
    --now-bg: rgba(34,197,94,0.12);
    --short: #38bdf8;
    --short-bg: rgba(56,189,248,0.12);
    --medium: #f59e0b;
    --medium-bg: rgba(245,158,11,0.12);
    --strategic: #e879f9;
    --strategic-bg: rgba(232,121,249,0.12);
    --low: #16a34a;
    --low-bg: rgba(22,163,74,0.08);
    --mid-effort: #b45309;
    --mid-effort-bg: rgba(180,83,9,0.08);
    --high: #dc2626;
    --high-bg: rgba(220,38,38,0.08);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    min-height: 100vh;
    padding: 32px 24px 60px;
  }

  /* Header */
  .header { margin-bottom: 32px; }
  .header-top { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 6px; }
  .title {
    font-family: 'Syne', sans-serif;
    font-size: 22px;
    font-weight: 800;
    color: #1a1e2e;
    letter-spacing: -0.5px;
  }
  .subtitle {
    font-size: 12px;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    margin-top: 4px;
  }
  .reckitt-brand {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }
.reckitt-divider {
    width: 1px;
    height: 22px;
    background: var(--border);
  }
  .reckitt-sub {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    line-height: 1.35;
  }

  /* Stat cards */
  .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 28px; }
  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 16px 18px;
    position: relative;
    overflow: hidden;
    cursor: default;
    transition: border-color 0.2s;
  }
  .stat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
  }
  .stat-card.now::before { background: var(--now); }
  .stat-card.short::before { background: var(--short); }
  .stat-card.medium::before { background: var(--medium); }
  .stat-card.strategic::before { background: var(--strategic); }
  .stat-card:hover { border-color: #3a4055; }
  .stat-num {
    font-family: 'Syne', sans-serif;
    font-size: 40px;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 6px;
  }
  .stat-card.now .stat-num { color: var(--now); }
  .stat-card.short .stat-num { color: var(--short); }
  .stat-card.medium .stat-num { color: var(--medium); }
  .stat-card.strategic .stat-num { color: var(--strategic); }
  .stat-label {
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: 4px;
  }
  .stat-desc { font-size: 11px; color: #6b7280; line-height: 1.4; }

  /* Filters */
  .filter-group { margin-bottom: 8px; }
  .filter-group:last-of-type { margin-bottom: 20px; }
  .filters { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }
  .filter-label { font-size: 11px; color: var(--muted); font-family: 'DM Mono', monospace; margin-right: 4px; white-space: nowrap; width: 110px; flex-shrink: 0; }
  .filter-btn {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    padding: 5px 14px;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.15s;
    letter-spacing: 0.03em;
  }
  .filter-btn:hover { border-color: #3a4055; color: var(--text); }
  .filter-btn.active { color: #fff; border-color: transparent; }
  .filter-btn.active.all { background: #252a38; color: #fff; }
  .filter-btn.active.now { background: var(--now-bg); border-color: var(--now); color: var(--now); }
  .filter-btn.active.short { background: var(--short-bg); border-color: var(--short); color: var(--short); }
  .filter-btn.active.medium { background: var(--medium-bg); border-color: var(--medium); color: var(--medium); }
  .filter-btn.active.strategic { background: var(--strategic-bg); border-color: var(--strategic); color: var(--strategic); }

  /* Area filter button colours */
  .filter-btn.active.area-inbound  { background: rgba(20,184,166,0.12); border-color: #14b8a6; color: #14b8a6; }
  .filter-btn.active.area-dispensary { background: rgba(251,146,60,0.12); border-color: #fb923c; color: #fb923c; }
  .filter-btn.active.area-processing { background: rgba(99,102,241,0.14); border-color: #818cf8; color: #818cf8; }
  .filter-btn.active.area-fillpack  { background: rgba(232,121,249,0.12); border-color: #e879f9; color: #e879f9; }
  .filter-btn.active.area-qcrelease { background: rgba(248,113,113,0.12); border-color: #f87171; color: #f87171; }
  .filter-btn.active.area-dispatch  { background: rgba(148,163,184,0.12); border-color: #94a3b8; color: #94a3b8; }

  /* Area dot on stream tag */
  .area-dot {
    display: inline-block;
    width: 6px; height: 6px;
    border-radius: 50%;
    margin-right: 5px;
    vertical-align: middle;
    position: relative; top: -1px;
  }

  /* Search */
  .search-wrap { flex: 1; max-width: 260px; margin-left: auto; position: relative; }
  .search-input {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 5px 10px 5px 32px;
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    outline: none;
    transition: border-color 0.15s;
  }
  .search-input:focus { border-color: #3a4055; }
  .search-input::placeholder { color: var(--muted); }
  .search-icon { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: var(--muted); font-size: 12px; }

  /* Table */
  .table-wrap { overflow-x: auto; border-radius: 10px; border: 1px solid var(--border); }
  table { width: 100%; border-collapse: collapse; }
  thead tr { background: var(--surface2); }
  th {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 10px 14px;
    text-align: left;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
    font-weight: 500;
  }
  th:first-child { padding-left: 18px; width: 36px; }

  tbody tr {
    border-bottom: 1px solid var(--border);
    transition: background 0.12s;
    animation: fadeRow 0.3s ease forwards;
    opacity: 0;
  }
  @keyframes fadeRow {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }
  tbody tr:last-child { border-bottom: none; }
  tbody tr:hover { background: var(--surface2); }
  td {
    padding: 11px 14px;
    vertical-align: top;
    color: var(--text);
    line-height: 1.45;
  }
  td:first-child { padding-left: 18px; color: var(--muted); font-family: 'DM Mono', monospace; font-size: 11px; }

  /* Badges */
  .badge {
    display: inline-block;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    padding: 3px 8px;
    border-radius: 4px;
    white-space: nowrap;
    letter-spacing: 0.02em;
  }
  .badge.now { background: var(--now-bg); color: var(--now); border: 1px solid rgba(34,197,94,0.25); }
  .badge.short { background: var(--short-bg); color: var(--short); border: 1px solid rgba(56,189,248,0.25); }
  .badge.medium { background: var(--medium-bg); color: var(--medium); border: 1px solid rgba(245,158,11,0.25); }
  .badge.strategic { background: var(--strategic-bg); color: var(--strategic); border: 1px solid rgba(232,121,249,0.25); }

  .effort {
    display: inline-block;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    padding: 3px 8px;
    border-radius: 4px;
    white-space: nowrap;
  }
  .effort.Low { background: var(--low-bg); color: var(--low); }
  .effort.Medium { background: var(--mid-effort-bg); color: var(--mid-effort); }
  .effort.High { background: var(--high-bg); color: var(--high); }

  .stream-tag {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    background: rgba(255,255,255,0.04);
    padding: 2px 7px;
    border-radius: 3px;
    border: 1px solid var(--border);
    white-space: nowrap;
  }

  .opp-name { font-weight: 500; color: #1a1e2e; font-size: 12.5px; margin-bottom: 2px; }
  .benefit-text { font-size: 11.5px; color: #374151; }
  .what-text { font-size: 11.5px; color: #4b5563; }

  .empty-state {
    padding: 60px 20px;
    text-align: center;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    display: none;
  }

  /* Row animation delays */
  tbody tr:nth-child(1) { animation-delay: 0.02s; }
  tbody tr:nth-child(2) { animation-delay: 0.04s; }
  tbody tr:nth-child(3) { animation-delay: 0.06s; }
  tbody tr:nth-child(4) { animation-delay: 0.08s; }
  tbody tr:nth-child(5) { animation-delay: 0.10s; }
  tbody tr:nth-child(6) { animation-delay: 0.12s; }
  tbody tr:nth-child(7) { animation-delay: 0.14s; }
  tbody tr:nth-child(8) { animation-delay: 0.16s; }
  tbody tr:nth-child(9) { animation-delay: 0.18s; }
  tbody tr:nth-child(10) { animation-delay: 0.20s; }
  tbody tr:nth-child(n+11) { animation-delay: 0.22s; }

  .count-line {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    margin-bottom: 10px;
    padding-left: 2px;
  }
  .count-line span { color: var(--text); }
</style>
</head>
<body>

<div class="header">
  <div class="header-top">
    <div>
      <div class="title">Gaviscon VSM — Opportunity &amp; Next Steps</div>
    </div>
    <div class="reckitt-brand">

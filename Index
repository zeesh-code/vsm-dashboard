let currentHorizon = 'all';
let currentArea    = 'all';
let currentSearch  = '';

function render() {
  const tbody     = document.getElementById('tbody');
  const emptyState = document.getElementById('emptyState');
  const tableWrap  = document.querySelector('.table-wrap table');

  const filtered = data.filter(row => {
    const matchHorizon = currentHorizon === 'all' || row.horizon === currentHorizon;
    const matchArea    = currentArea    === 'all' || row.area    === currentArea;
    const q = currentSearch.toLowerCase();
    const matchSearch  = !q ||
      row.opportunity.toLowerCase().includes(q) ||
      row.stream.toLowerCase().includes(q) ||
      row.benefit.toLowerCase().includes(q) ||
      row.what.toLowerCase().includes(q);
    return matchHorizon && matchArea && matchSearch;
  });

  document.getElementById('countLine').innerHTML =
    `Showing <span>${filtered.length}</span> of ${data.length} opportunities`;

  if (filtered.length === 0) {
    tbody.innerHTML = '';
    emptyState.style.display = 'block';
    tableWrap.style.display  = 'none';
  } else {
    emptyState.style.display = 'none';
    tableWrap.style.display  = '';
    tbody.innerHTML = filtered.map(row => {
      const am = AREA_META[row.area] || {};
      const dot = `<span class="area-dot" style="background:${am.color || '#6b7280'}"></span>`;
      return `
      <tr>
        <td>${row.id}</td>
        <td><span class="badge ${row.horizon}">${row.horizonLabel}</span></td>
        <td><span class="stream-tag">${dot}${row.stream}</span></td>
        <td><div class="opp-name">${row.opportunity}</div>
            <div style="margin-top:3px;font-size:10px;color:${am.color || '#6b7280'};font-family:'DM Mono',monospace;">${am.label || ''}</div></td>
        <td><div class="what-text">${row.what}</div></td>
        <td><div class="benefit-text">${row.benefit}</div></td>
        <td><span class="effort ${row.effort}">${row.effort}</span></td>
      </tr>`;
    }).join('');
  }
}

function filterHorizon(horizon, btn) {
  currentHorizon = horizon;
  btn.closest('.filters').querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  render();
}

function filterArea(area, btn) {
  currentArea = area;
  btn.closest('.filters').querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  render();
}

function search(val) {
  currentSearch = val;
  render();
}

render();
</script>
